# V language gitignore

# Compiled binaries
*.exe
*.out
*.vbin

# Compiled objects
*.o
*.so
*.dll

# Temporary files
*.tmp
*.temp
*~
.*~

# Build directories
build/
dist/
out/
.vpkg/

# V cache
.cache/
v_cache/
__v/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Log files
*.log
logs/

# Test artifacts
*.test
coverage/
.coverage

# Backup files
*.bak
*.backup

# Intermediate test results
final_output_*.txt

v/
/tests/cases/generated/**/001.v
/tests/cases/generated/**/002.v
/tests/cases/generated/**/003.v
/tests/cases/generated/**/004.v
/tests/cases/generated/**/005.v
vnake
vnake.exe
*.v.orig
/tmp
test_output.txt
out.txt
stderr.txt
full_actual.txt
full_actual*.txt
tests_final.txt
tests_final*.txt
tests_full.txt
tests_full*.txt
tests_reverted.txt
tests_reverted*.txt
tests_active_*.txt
tests_fix_*.txt
tests_pass_*.txt
tests_truly_*.txt
test_results.txt
test_results*.txt
