# V language gitignore

# Compiled binaries
*.exe
*.out
*.vbin

# Compiled objects
*.o
*.so
*.dll

# Temporary files
*.tmp
*.temp
*~
.*~

# Build directories
build/
dist/
out/
.vpkg/

# V cache
.cache/
v_cache/
__v/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Log files
*.log
logs/

# Test artifacts
*.test
coverage/
.coverage

# Backup files
*.bak
*.backup

# Intermediate test results
final_output_*.txt

v/
/tests/cases/generated/**/001.v
/tests/cases/generated/**/002.v
/tests/cases/generated/**/003.v
/tests/cases/generated/**/004.v
/tests/cases/generated/**/005.v
/tests/**/*_helpers.v
/tests/fortranslatemanually/*.v
vnake
vnake.exe
*.v.orig
*.v.rej
/tmp
out.txt
out*.txt
stderr.txt
full_*.txt
tests_*.txt
test_*.txt
*.diff
*.patch
raw_type_map_debug.json
v_errors.txt
build_*.txt
check_*.txt
v_err*.txt
v_out*.txt
